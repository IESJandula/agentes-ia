# 1. Usamos Python 3.12 slim (más ligero)
FROM python:3.12-slim

# 2. Configuraciones de entorno
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PORT=8010
WORKDIR /app

# 3. Instalamos dependencias del sistema NECESARIAS
# Añadimos librerías para procesamiento de imágenes, PDF y OCR (libxcb, libgl, etc.)
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libffi-dev \
    libssl-dev \
    libgl1 \
    libglib2.0-0 \
    libxcb1 \
    libx11-6 \
    libxext6 \
    libxrender1 \
    libsm6 \
    libgomp1 \
    && rm -rf /var/lib/apt/lists/*

# 4. Instalamos las dependencias de Python PASO A PASO para no agotar la RAM
RUN pip install --no-cache-dir --upgrade pip setuptools wheel

# A. Instalamos Torch CPU primero (muy pesado)
RUN pip install --no-cache-dir torch --extra-index-url https://download.pytorch.org/whl/cpu

# B. Instalamos Docling y dependencias de imagen (muy pesado)
RUN pip install --no-cache-dir "docling[standard]" transformers accelerate Pillow timm torchvision --extra-index-url https://download.pytorch.org/whl/cpu

# C. Instalamos el resto de dependencias
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 5. Playwright para navegación web
RUN playwright install --with-deps chromium

# 6. Copiamos el resto de la aplicación
COPY . .

# 7. Volumen local persistente para la base de datos Chroma
VOLUME /app/data/chroma_db_v3

# 8. Exponemos el puerto 8010 (no 8000, porque está ocupado en Coolify)
EXPOSE 8010

# 8. Health check (opcional pero recomendado en Coolify)
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD python -c "import requests; requests.get('http://localhost:8010/api', timeout=5)" || exit 1

# 9. Comando de ejecución
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8010"]
